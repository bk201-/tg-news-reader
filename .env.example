TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here
TG_SESSION=
SERVER_PORT=3173

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── Download Manager ─────────────────────────────────────────────────────────
# Number of concurrent download workers
DOWNLOAD_WORKER_CONCURRENCY=10
# How long (seconds) to keep a completed task before auto-deleting it
DOWNLOAD_TASK_CLEANUP_DELAY_SEC=30

# ─── Media size limits (background downloads only; user-initiated bypass these) ──
MAX_PHOTO_SIZE_MB=5
MAX_VIDEO_SIZE_MB=75
MAX_IMG_DOC_SIZE_MB=5

# ─── News fetching ────────────────────────────────────────────────────────────
# Days to look back for a brand-new channel's first fetch
NEWS_DEFAULT_FETCH_DAYS=3
# Max messages fetched per channel sync
NEWS_FETCH_LIMIT=1000
