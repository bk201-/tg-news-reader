{
  "name": "tg-news-reader",
  "version": "1.14.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"blue,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --tsconfig tsconfig.server.json src/server/index.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --tsconfig tsconfig.server.json src/server/db/migrate.ts",
    "tg:auth": "tsx --tsconfig tsconfig.server.json scripts/tg-auth.ts",
    "tg:auth:deploy": "tsx --tsconfig tsconfig.server.json scripts/tg-auth-deploy.ts",
    "auth:create-user": "tsx --tsconfig tsconfig.server.json scripts/create-user.ts",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "checkup": "npm run build && npm run build:server && npm run format && npm run lint"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.17.2",
    "@mozilla/readability": "^0.6.0",
    "@tanstack/react-query": "^5.96.2",
    "@types/turndown": "^5.0.6",
    "antd": "^6.3.5",
    "antd-style": "^4.1.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "hono-rate-limiter": "^0.5.3",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "openai": "^6.33.0",
    "otpauth": "^9.5.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "react-virtuoso": "^4.18.4",
    "remark-gfm": "^4.0.1",
    "jsdom": "^29.0.2",
    "telegram": "^2.26.22",
    "turndown": "^7.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.19.17",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.4"
  }
}
