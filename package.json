{
  "name": "tg-news-reader",
  "version": "1.25.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"blue,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --tsconfig tsconfig.server.json src/server/index.ts",
    "build": "vite build",
    "build:client": "tsc",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --tsconfig tsconfig.server.json src/server/db/migrate.ts",
    "tg:auth": "tsx --tsconfig tsconfig.server.json scripts/tg-auth.ts",
    "tg:auth:deploy": "tsx --tsconfig tsconfig.server.json scripts/tg-auth-deploy.ts",
    "auth:create-user": "tsx --tsconfig tsconfig.server.json scripts/create-user.ts",
    "lint": "oxlint --quiet",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "checkup": "npm run build && npm run build:server && npm run format && npm run lint"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@azure/cosmos": "^4.9.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "@libsql/client": "^0.17.3",
    "@mozilla/readability": "^0.6.0",
    "@tanstack/react-query": "^5.100.14",
    "@types/turndown": "^5.0.6",
    "antd": "^6.4.3",
    "antd-style": "^4.1.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "hono-rate-limiter": "^0.5.3",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsdom": "^29.1.1",
    "openai": "^6.39.0",
    "otpauth": "^9.5.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4.0.1",
    "telegram": "^2.26.22",
    "turndown": "^7.2.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
