{
  "name": "tg-news-reader",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"blue,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --tsconfig tsconfig.server.json src/server/index.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --tsconfig tsconfig.server.json src/server/db/migrate.ts",
    "tg:auth": "tsx --tsconfig tsconfig.server.json scripts/tg-auth.ts",
    "auth:create-user": "tsx --tsconfig tsconfig.server.json scripts/create-user.ts",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@hono/node-server": "^1.14.0",
    "@libsql/client": "^0.17.0",
    "@mozilla/readability": "^0.6.0",
    "@tanstack/react-query": "^5.80.0",
    "antd": "^6.3.0",
    "antd-style": "^4.1.0",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.13",
    "dotenv": "^17.0.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.7.0",
    "hono-rate-limiter": "^0.5.3",
    "i18next": "^25.8.20",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsdom": "^29.0.0",
    "otpauth": "^9.5.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.0.0",
    "telegram": "^2.26.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0"
  }
}
